{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Savedrive",
  "version": "0.1.0",
  "identifier": "com.telegram.drive",
  "build": {
    "frontendDist": "./ui",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Savedrive",
        "width": 1280,
        "height": 840,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
